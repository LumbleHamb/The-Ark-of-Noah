[autoload]

save_manager="*res://scripts/world/save_manager.gd"
virtual_joystick="*res://scripts/ui/virtual_joystick.gd"
scene_transition="*res://scripts/autoload/scene_transition.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
